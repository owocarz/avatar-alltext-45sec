# yt-clip-service environment variables
# Copy to .env and fill in values

# YouTube bridge (PC user's bridge URL — changes on Cloudflare tunnel restart)
YT_BRIDGE_URL=https://xxxx.trycloudflare.com
YT_BRIDGE_SECRET=zaxbridge_2026

# X (Twitter) API Bearer token — for X clips source
X_BEARER_TOKEN=

# Pexels API key — for Pexels fallback
PEXELS_API_KEY=

# YT proxy (optional, leave empty — VPS IP blocked by YT anyway)
YT_PROXY=

# Legacy / unused
YT_COOKIES_B64=
YOUTUBE_API_KEY=
REPLICATE_API_TOKEN=
